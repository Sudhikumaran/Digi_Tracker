NODE_ENV=development
PORT=5000
JWT_SECRET=digitracker-jwt-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=digitracker-refresh-secret-change-in-production-min-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
# In development, all localhost ports are allowed automatically (Flutter web uses random ports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
APP_URL=http://localhost:5173
FIREBASE_PROJECT_ID=digi-tracker-8b0be
# Default path: backend/credentials/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_PATH=./credentials/firebase-service-account.json
